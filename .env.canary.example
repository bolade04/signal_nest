# =============================================================================
# .env.canary.example — SIGNALNEST_STAGING placeholder template (INFRA-3)
# =============================================================================
# PLACEHOLDER ONLY. This file contains NO real secret, NO AWS account id, NO
# ARN, and NO tenant id. It is a values-free reference of environment-variable
# NAMES and their reviewed staging disposition. Do NOT paste real credentials
# here and do NOT commit a filled-in copy.
#
# Environment-variable names equal the UPPERCASED field name in
# apps/api/app/core/config.py (there is no env_prefix). The authoritative
# disposition contract is docs/operations/aws-staging-secret-inventory.md.
#
# Injection contract (see the inventory, §5):
#   [SECRETS MANAGER] injected ONLY via the ECS task-definition `secrets` block
#                     (valueFrom a Secrets Manager ARN). NEVER plaintext env,
#                     NEVER a Docker build arg / image label / mutable tag.
#                     Left blank here on purpose.
#   [IAM ROLE]        supplied by the ECS task-role credential chain. MUST stay
#                     unset. Do not provide a literal.
#   [ABSENT]          not part of the staging profile; leave unset.
#   [LOCAL ONLY]      developer convenience; unset or safe default in staging.
#   everything else   non-secret configuration, safe as plaintext task env.
# =============================================================================

# --- SECRETS MANAGER (blank on purpose — injected at runtime) ----------------
SECRET_KEY=
DATABASE_URL=
# REDIS_URL: only when the staging profile enables a Redis-backed cache/queue.
REDIS_URL=
LLM_API_KEY=

# --- IAM ROLE (leave unset — task-role credential chain) ---------------------
# S3_ACCESS_KEY_ID=      # do not set; use the ECS task role
# S3_SECRET_ACCESS_KEY=  # do not set; use the ECS task role

# --- ABSENT IN STAGING (leave unset) -----------------------------------------
# OTLP_ENDPOINT=         # staging observability is CloudWatch, not OTLP
# S3_ENDPOINT_URL=       # native AWS S3 default endpoint

# --- LOCAL-DEVELOPMENT-ONLY (unset / safe default in staging) ----------------
# LOCAL_STORAGE_DIR=     # staging uses S3 object storage
# LLM_MOCK_SEED=         # mock provider is forbidden in staging
LLM_ALLOW_DEV_FALLBACK=false

# --- FEATURE FLAGS (non-secret; MUST remain false for the dark canary) -------
OPPORTUNITY_FEEDBACK_ENABLED=false
SCOUT_SCHEDULING_ENABLED=false
CONNECTOR_RSS_ENABLED=false

# --- GENERAL / API (non-secret) ----------------------------------------------
APP_NAME=SignalNest API
APP_MODE=full
ENVIRONMENT=staging
DEBUG=false
API_PREFIX=/api/v1

# --- OBSERVABILITY / TRACING (non-secret) ------------------------------------
SERVICE_NAME=signalnest-api
LOG_FORMAT=json
METRICS_ENABLED=true
TRACING_ENABLED=false
TRACING_EXPORTER=none
TRACING_SAMPLE_RATIO=0.05
TRACING_EXPORT_TIMEOUT_SECONDS=10.0
TRACING_SHUTDOWN_FLUSH_SECONDS=5.0
TRACING_MAX_QUEUE_SIZE=2048
TRACING_PROPAGATION=tracecontext

# --- SECURITY (non-secret) ---------------------------------------------------
ACCESS_TOKEN_EXPIRE_MINUTES=720
CORS_ORIGINS=["https://staging.example.invalid"]

# --- POSTGRESQL POOL (non-secret) --------------------------------------------
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=30.0
DB_POOL_RECYCLE_SECONDS=1800.0
DB_CONNECT_TIMEOUT_SECONDS=10.0
DB_APPLICATION_NAME=signalnest-api

# --- OBJECT STORAGE (non-secret; bucket name is an identifier) ---------------
STORAGE_BACKEND=s3
S3_BUCKET=
S3_REGION=us-east-1
S3_USE_SSL=true
S3_MAX_OBJECT_BYTES=26214400
S3_SIGNED_URL_TTL_SECONDS=900
S3_OPERATION_TIMEOUT_SECONDS=10.0
S3_MAX_RETRIES=3

# --- REDIS TUNING (non-secret) -----------------------------------------------
REDIS_POOL_SIZE=10
REDIS_OPERATION_TIMEOUT_SECONDS=2.0
REDIS_KEY_PREFIX=signalnest
REDIS_NOTIFY_CHANNEL=signalnest:jobs:available
REDIS_LOCK_TTL_SECONDS=30.0

# --- VECTOR / JOB BACKENDS (non-secret) --------------------------------------
VECTOR_BACKEND=pgvector
EMBEDDING_DIM=256
QUEUE_BACKEND=redis
CACHE_BACKEND=redis

# --- DURABLE JOB / WORKER EXECUTION (non-secret) -----------------------------
JOB_QUEUE_BACKEND=local
# WORKER_ID=                       # optional; derived when unset
WORKER_CONCURRENCY=1
WORKER_POLL_INTERVAL_SECONDS=1.0
WORKER_LEASE_SECONDS=30.0
WORKER_HEARTBEAT_SECONDS=10.0
WORKER_SHUTDOWN_GRACE_SECONDS=10.0
WORKER_FORCE_SHUTDOWN_GRACE_SECONDS=1.0
JOB_DEFAULT_MAX_ATTEMPTS=5
JOB_RETRY_BASE_SECONDS=2.0
JOB_RETRY_MAX_SECONDS=300.0
JOB_MAX_PAYLOAD_BYTES=65536
JOB_CLAIM_BATCH_SIZE=1
READINESS_CACHE_TTL_SECONDS=0.0

# --- WORKER FLEET REGISTRY (non-secret) --------------------------------------
WORKER_TYPE=durable-jobs
WORKER_STALE_AFTER_SECONDS=60.0
WORKER_REGISTRATION_RETRY_LIMIT=3
WORKER_REGISTRATION_RETRY_DELAY_SECONDS=1.0
WORKER_ID_MAX_LENGTH=128
REQUIRE_WORKER_FLEET=false
APPLICATION_VERSION=0.0.0
# BUILD_REVISION=                  # optional build id

# --- SCOUTING CONNECTORS (dark; non-secret) ----------------------------------
CONNECTOR_RSS_MARKETS=[]
CONNECTOR_RSS_RATE_CAPACITY=5
CONNECTOR_RSS_RATE_REFILL_PER_SECOND=1.0
CONNECTOR_RSS_MAX_ATTEMPTS=3

# --- LLM (non-secret parts; key is above under SECRETS MANAGER) --------------
LLM_PROVIDER=openai
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_TEMPERATURE=0.0

# --- READINESS PROBES (non-secret) -------------------------------------------
READINESS_PROBE_TIMEOUT_SECONDS=2.0
READINESS_TOTAL_TIMEOUT_SECONDS=5.0
