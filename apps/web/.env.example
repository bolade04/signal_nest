# In dev the API is reached through the Vite proxy (see vite.config.ts), so this
# can stay blank locally. Set it in production to the backend origin, e.g.
# VITE_API_BASE_URL=https://api.signalnest.example
VITE_API_BASE_URL=

# Optional: override the dev proxy target (defaults to http://127.0.0.1:8000)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000
